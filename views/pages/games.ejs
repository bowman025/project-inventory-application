<%- include('../partials/header') %>
<main>
  <div class="all-games">
    <div class="games-top">
      <h1>All Games</h1>
      <a href="/games/new">ADD A GAME</a>
    </div>
    <div class="game-grid">
      <% if (games && games.length > 0) { %>
        <% games.forEach(game => { %>
          <div class="game-card" style="background-image: url('<%= game.background %>');">
            <a href="/games/<%= game.id %>">
              <img src="<%= game.image %>" alt="<%= game.name %>">
            </a>
            <h2><a href="/games/<%= game.id %>"><%= game.name %></a></h2>
          </div>
        <% }); %>
      <% } else { %>
        <p>No games found.</p>
      <% } %>
    </div>
  </div>
</main>
<%- include('../partials/footer') %>
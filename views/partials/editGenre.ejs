<dialog id="edit-genre">
  <form action="/genres/<%= genreId %>/edit" method="post">
    <div class="edit-genre-name">
      <label for="genre" class="accented-text">Change Name:</label>
      <input
        type="text"
        name="name"
        id="genre"
        value="<%= genreName %>"
        maxlength="50"
        minlength="1"
      >
    </div>
    <div class="edit-games">
      <% if (games.length > 0) { %>
        <div class="edit-remove-games">
          <p class="accented-text">Remove Game(s):</p>
          <% if (games.length > 1) { %>
            <div class="associated-game-check">
              <input type="checkbox" id="toggle-all-remove">
              <label for="toggle-all-remove">
                Select All
              </label>
            </div>
          <% } %>
          <div class="associated-game-list">
            <% games.forEach(game => { %>
              <div class="associated-game">
                <input
                  type="checkbox"
                  name="gameIds"
                  value="<%= game.id %>"
                  class="game-checkbox-remove"
                  id="game-<%= game.id %>"
                >
                <label for="game-<%= game.id %>">
                  <%= game.name %>
                </label>
              </div>
            <% }); %>
          </div>
        </div>
      <% } %>
      <% if (allGames.length > 0) { %>
        <div class="edit-add-games">
          <p class="accented-text">Add Game(s):</p>
          <% if (allGames.length > 1) { %>
            <div class="all-game-check">
              <input type="checkbox" id="toggle-all-add">
              <label cfor="toggle-all-add">
                Select All
              </label>
            </div>
          <% } %>
          <div class="all-game-list">
            <% allGames.forEach(allGame => { %>
              <div class="all-game">
                <input
                  type="checkbox"
                  name="allGameIds"
                  value="<%= allGame.id %>"
                  class="game-checkbox-add"
                  id="all-game-<%= allGame.id %>"
                >
                <label for="game-<%= allGame.id %>">
                  <%= allGame.name %>
                </label>
              </div>
            <% }); %>
          </div>
        </div>
      <% } %>
    </div>
    <div class="edit-admin-password">
      <label for="password" class="accented-text">Admin Password:</label>
      <input
        type="password"
        id="password"
        name="password"
        maxlength="50"
        minlength="1"
        placeholder="Password"
        required
      >
    </div>
    <button type="submit">SUBMIT</button>
  </form>
  <button commandfor="edit-genre" command="close">
    CLOSE
  </button>
</dialog>
<dialog id="add-game">
  <form action="/games" method="post">
    <p>Let's keep this simple.</p>
    <p>Please provide a valid Steam ID and we'll take care of the rest.</p>
    <label for="steamId">Steam ID:</label>
    <input 
      type="number" 
      id="steamId" 
      name="steamId"
      min="1"
      max="9999999999"
      required
    >
    <button type="submit">Submit</button>
  </form>
  <button commandfor="add-game" command="close">Close</button>
</dialog>